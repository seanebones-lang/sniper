# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
/playwright-report/
/test-results/
/blob-report/

# next.js
/.next/
/out/

# production
/build
/dist

# ============================================================================
# SNIPER — CRITICAL: NEVER COMMIT SECRETS OR TRADING KEYS
# ============================================================================
.env
.env.local
.env.*.local
.envrc
.env.development.local
.env.test.local
.env.production.local

# Private keys / wallets (Polymarket, Kalshi, etc.)
*.pem
*private*.key
*secret*.key
*.p12
*.key

# Local DB / logs / data
*.db
*.log
/data/
db/data/
*.sqlite
*.sqlite3

# ============================================================================
# REPO HYGIENE — Prevent nested copies and bloat (learned the hard way)
# ============================================================================
# Never allow a full copy of the project inside itself
sniper/
# Common duplicate folder names seen in this project history
sniper-*/
backup*/
old*/
archive*/

# OS / editor
.DS_Store
*.swp
*.swo
.idea/
.vscode/
*.code-workspace

# Build artifacts
*.tsbuildinfo
next-env.d.ts
*.map
dist/
build/

# Debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
lerna-debug.log*

# Misc
.vercel
*.local
*.cache
recovered-from-transcript/

# Allow specific env files if needed (commented for safety)
# !.env.example
