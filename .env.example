# Sniper — environment template
# Copy to .env.local and fill in values. Never commit .env.local.

# Required — PostgreSQL connection string
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/sniper

# Paper mode is the default. Real execution requires explicit opt-in below.
# SNIPER_ENABLE_REAL_EXECUTION=false
# Geoblock uses server egress IP — US/UK/etc are blocked by Polymarket CLOB (403).
# Railway: deploy with `eu-west=1` (see docs/DEPLOY-RAILWAY.md). Local US: use VPN or POLYMARKET_HTTP_PROXY.
# SNIPER_SKIP_GEOBLOCK_CHECK only skips runner warnings; real orders still call polymarket.com/api/geoblock.
# SNIPER_SKIP_GEOBLOCK_CHECK=false

# Railway production (after deploy)
# SNIPER_AUTO_START_RUNNER=true
# POLYMARKET_HTTP_PROXY=http://user:pass@host:port   # required on Railway (US egress); optional for local VPN bypass
# If geoblock OK but orders 403: paste browser session (or save via /real UI)
# POLYMARKET_CF_CLEARANCE=
# POLYMARKET_USER_AGENT=Mozilla/5.0 ...

# Per-trade real-money ceiling (USD). Defaults to 1 so live trading starts very
# small. Every real order is clamped to this; raise it only after you've verified
# real fills end-to-end. Also requires a strategy with paperOnly=false.
# Note: ~$1 is near venue minimums (Polymarket/Kalshi); some orders may be
# rejected by the exchange below their minimum notional.
# SNIPER_MAX_REAL_USD_PER_TRADE=1

# Polymarket real trading (only if SNIPER_ENABLE_REAL_EXECUTION=true)
# Use a dedicated low-balance wallet. Never commit this key.
# POLYMARKET_PRIVATE_KEY=
# Optional proxy wallet (Magic/email login): set signature type + funder address
# POLYMARKET_SIGNATURE_TYPE=3   # 0=EOA, 1=POLY_PROXY, 2=GNOSIS_SAFE, 3=deposit wallet (most new accounts)
# POLYMARKET_FUNDER_ADDRESS=0x...
# Optional: persist CLOB L2 creds (or derive at runtime via createOrDeriveApiKey)
# POLYMARKET_API_KEY=
# POLYMARKET_API_SECRET=
# POLYMARKET_API_PASSPHRASE=
# Gasless relayer (Settings > API Keys) — auto-approves pUSD for trading
# RELAYER_API_KEY=
# RELAYER_API_KEY_ADDRESS=0x...   # address that owns the relayer key (your signer EOA)
# Run: npx tsx scripts/sync-env-credentials.ts
# Or legacy builder HMAC (same keys page):
# POLY_BUILDER_API_KEY=
# POLY_BUILDER_SECRET=
# POLY_BUILDER_PASSPHRASE=

# Kalshi API (WebSocket book hub + real trading). Generate RSA key in Kalshi dashboard.
# KALSHI_ACCESS_KEY=
# KALSHI_RSA_PRIVATE_KEY=   # full PEM, or use \n for newlines in one line

# Grok / xAI — optional; can also be set in Settings UI (/settings)
# XAI_API_KEY=
# ENABLE_GROK_RESEARCH_AGENT=false

# Telegram alerts — optional but recommended for 24/7 operation
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=

# Local dev: smoke/e2e default to http://localhost:3001 when dev server is running
# SMOKE_BASE_URL=http://localhost:3001
# PLAYWRIGHT_BASE_URL=http://localhost:3001
