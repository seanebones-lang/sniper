# Sniper — environment template
# Copy to .env.local and fill in values. Never commit .env.local.

# Required — PostgreSQL connection string
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/sniper

# Paper mode is the default. Real execution requires explicit opt-in below.
# SNIPER_ENABLE_REAL_EXECUTION=false

# Polymarket real trading (only if SNIPER_ENABLE_REAL_EXECUTION=true)
# Use a dedicated low-balance wallet. Never commit this key.
# POLYMARKET_PRIVATE_KEY=

# Kalshi real trading (not yet implemented in executor)
# KALSHI_API_KEY_ID=
# KALSHI_PRIVATE_KEY_PATH=

# Grok / xAI — optional; can also be set in Settings UI (/settings)
# XAI_API_KEY=
# ENABLE_GROK_RESEARCH_AGENT=false

# Telegram alerts — optional but recommended for 24/7 operation
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=

# Local dev: smoke/e2e default to http://localhost:3001 when dev server is running
# SMOKE_BASE_URL=http://localhost:3001
# PLAYWRIGHT_BASE_URL=http://localhost:3001
