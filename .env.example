# ============================================================================
# SNIPER — Polymarket / Kalshi 24/7 Trading System
# ============================================================================
# ⚠️  CRITICAL WARNINGS — READ FULLY BEFORE USE
#
# 1. REAL CAPITAL RISK: Prediction market trading can (and often does) result
#    in 100% loss of capital. This software makes it easier and faster to lose
#    money if your chosen "edges" do not exist or are eroded by fees/slippage.
#
# 2. PAPER MODE IS THE DEFAULT AND RECOMMENDED MODE. Real trading is an
#    advanced, opt-in feature that requires explicit environment flags + UI
#    confirmation. Never enable real trading until you have run paper strategies
#    for weeks with positive expectancy and understand every line of code.
#
# 3. KEY CUSTODY: You (and only you) are responsible for your private keys and
#    API credentials. Never commit them. Never share them. This app reads them
#    ONLY from the server environment at runtime.
#
# 4. LEGAL & COMPLIANCE: You are solely responsible for all legal, tax, and
#    regulatory obligations in your jurisdiction. Polymarket has access
#    restrictions; Kalshi is CFTC-regulated. This is not financial, legal, or
#    investment advice.
#
# 5. 24/7 OPERATION: Running always-on requires a paid Railway (or equivalent)
#    plan + your own monitoring. Bugs, API changes, or outages can cause
#    unexpected behavior or losses.
#
# ============================================================================

# --- Core (required for local dev + Railway) ---
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/sniper
# Railway injects this automatically when you add Postgres plugin.

NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Optional: xAI Grok for research/summaries (Phase 5+) ---
# XAI_API_KEY=

# ============================================================================
# TRADING CREDENTIALS — TREAT AS HIGHLY SENSITIVE
# ============================================================================
# These are ONLY used when you explicitly enable real execution (env guard +
# UI confirmation). They are never sent to the browser or stored in the DB.

# Polymarket (CLOB V2, Polygon mainnet)
# WARNING: This is a hot wallet private key. Use a dedicated low-balance wallet.
# POLYMARKET_PRIVATE_KEY=0x...

# Kalshi (RSA keypair — generate in your Kalshi account under API Keys)
# KALSHI_ACCESS_KEY=your-key-id
# KALSHI_RSA_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"

# Demo / paper-only flag (strongly recommended while experimenting)
# SNIPER_PAPER_ONLY=true

# Feature flags (future use)
# SNIPER_ENABLE_REAL_EXECUTION=false
